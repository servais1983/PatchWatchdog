# ──────────────────────────────────────────────────────────────────────────────
# PatchWatchdog — Configuration des intégrations
# Copiez ce fichier en .env et remplissez vos valeurs réelles.
# ──────────────────────────────────────────────────────────────────────────────

# Notification Slack (Incoming Webhook)
# App Slack → Incoming Webhooks → copiez l'URL ici
SLACK_WEBHOOK=https://hooks.slack.com/services/XXXXX/XXXXX/XXXXX

# Notification GitHub Issues
# Token personnel avec permission "repo" (Settings → Developer Settings → Tokens)
GITHUB_TOKEN=ghp_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
# Format : utilisateur/nom-repo
GITHUB_REPO=votre_utilisateur/votre_repository

# Analyse des packages système via Vulners (optionnel — plan payant)
# Sans cette clé, seuls les packages pip sont analysés via OSV.dev (gratuit)
VULNERS_API_KEY=